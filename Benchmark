# ENGINEERED FEATURES (MMSE-BC locked-feature pipeline)
# ═══════════════════════════════════════════════════════════════════════

def max_cosim(E, tgt, seeds):
    """Max cosine similarity to the seed set, leave-self-out masked."""
    T, S = E[np.asarray(tgt)], E[np.asarray(seeds)]
    sim = (T @ S.T).astype(np.float32)
    eq = np.asarray(tgt)[:, None] == np.asarray(seeds)[None, :]
    if eq.any():
        sim = sim.copy(); sim[eq] = np.nan
    m = np.nanmax(sim, axis=1)
    return np.where(np.isnan(m), 0.0, m).astype(np.float32)


def assemble_X(feat_keys, mods, omics, log_deg, tgt, seeds, rwr_arr, m2_arr=None):
    tgt = np.asarray(tgt); cols = []
    for k in feat_keys:
        if k == "max_seq":
            cols.append(max_cosim(mods["seq"], tgt.tolist(), seeds))
        elif k == "max_struct":
            cols.append(max_cosim(mods["struct"], tgt.tolist(), seeds))
        elif k == "max_go":
            cols.append(max_cosim(mods["go"], tgt.tolist(), seeds))
        elif k == "rwr":
            cols.append(rwr_arr[tgt])
        elif k == "markov2":
            cols.append(m2_arr[tgt] if m2_arr is not None else np.zeros(len(tgt), np.float32))
        elif k == "log_deg":
            cols.append(log_deg[tgt])
        elif k in ("mut", "cna", "expr"):
            cols.append(omics[k][tgt])
    return np.column_stack(cols).astype(np.float32)


def run_mmse_bc_lr(data, locked_feats):
    """MMSE-BC: logistic regression on the locked engineered feature set."""
    print(f"\n── MMSE-BC LR (locked: {locked_feats}) ─────────────────")
    N, W = data["N"], data["W"]
    hp_train = data["hp_train"]
    hp_test, neg_test = data["hp_test"], data["neg_test"]
    all_hp = set(hp_train.tolist()) | set(hp_test.tolist())
    bg_pool = np.array([i for i in range(N) if i not in all_hp
                         and i not in set(neg_test.tolist())], np.int64)

    rng = np.random.default_rng(CFG["BASE_SEED"])
    n_neg = min(len(hp_train) * CFG["NEG_RATIO"], len(bg_pool))
    neg = rng.choice(bg_pool, n_neg, replace=False)
    pool = np.concatenate([hp_train, neg])
    y_pool = np.array([1] * len(hp_train) + [0] * len(neg), np.int32)

    si = hp_train.tolist()
    rwr_arr = rwr_fn(W, N, si)
    m2_arr = markov2_fn(W, N, si) if "markov2" in locked_feats else None

    X_pool = assemble_X(locked_feats, data["mods"], data["omics"], data["log_deg"],
                         pool.tolist(), si, rwr_arr, m2_arr)
    X_all = assemble_X(locked_feats, data["mods"], data["omics"], data["log_deg"],
                        list(range(N)), si, rwr_arr, m2_arr)
    scaler = StandardScaler().fit(X_pool)
    clf = LogisticRegression(class_weight="balanced", max_iter=2000,
                              C=1.0, random_state=CFG["BASE_SEED"])
    clf.fit(scaler.transform(X_pool), y_pool)
    scores = clf.predict_proba(scaler.transform(X_all))[:, 1].astype(np.float32)

    coef_str = ", ".join(f"{k}={v:+.3f}" for k, v in zip(locked_feats, clf.coef_[0]))
    print(f"  coef: {coef_str}")
    return scores


