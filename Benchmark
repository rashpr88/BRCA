        print(f"  Loaded locked config from {CFG['ablation_json']}: winner={winner}")
    else:
        locked_feats = DEFAULT_LOCKED_FEATS
        print(f"  No ablation_detail.json found — using default locked feats: {locked_feats}")

    data = load_data()
    y_test, test_idx = data["y_test"], data["test_idx"]
    N, A, W, G, nodes = data["N"], data["A"], data["W"], data["G"], data["nodes"]
    hp_train_set = set(data["hp_train"].tolist())

    all_results, all_scores = [], {}

    # ── Classical topology baselines ────────────────────────────────
    rwr_scores = rwr_fn(W, N, data["hp_train"].tolist())
    m2_scores = markov2_fn(W, N, data["hp_train"].tolist())
    classical = {
        "RWR":        rwr_scores,
        "Markov-2":   m2_scores,
        "MV":         mv_scores_fn(A, N, hp_train_set),
        "Hishigaki":  hishigaki_fn(A, N, hp_train_set),
        "NIAPU":      niapu_fn(W, A, N, hp_train_set),
        "LocalNbr":   local_nbr_fn(G, nodes, hp_train_set),
    }
    for name, sc in classical.items():
        r = evaluate(sc.astype(np.float64), y_test, test_idx, name)
        all_results.append(r); all_scores[name] = sc
        print(f"  {name:<12} AUPR={r['test_aupr']:.4f}  AUROC={r['test_auroc']:.4f}  Fmax={r['fmax']:.4f}")

    # ── MMSE-BC LR (engineered, locked features) ────────────────────
    mmse_scores = run_mmse_bc_lr(data, locked_feats)
    mmse_result = evaluate(mmse_scores, y_test, test_idx, "MMSE-BC ★")
    all_results.append(mmse_result); all_scores["MMSE-BC ★"] = mmse_scores
    print(f"  AUPR={mmse_result['test_aupr']:.4f}  AUROC={mmse_result['test_auroc']:.4f}  Fmax={mmse_result['fmax']:.4f}")

    # ── Published learned baselines ──────────────────────────────────
    for fn in (run_n2v_xgb, run_rf_feat_only, run_oncoplex):
        try:
            out = fn(data)
            if out:
                r, sc = out
                all_results.append(r); all_scores[r["method"]] = sc
        except Exception as e:
            import traceback; print(f"  ⚠  {fn.__name__} FAILED: {e}"); traceback.print_exc()

    # ── GCN / GAT — locked engineered features vs full 262-d PPI stack ─
    si = data["hp_train"].tolist()
    rwr_arr, m2_arr = rwr_fn(W, N, si), markov2_fn(W, N, si)
    X_locked = assemble_X(locked_feats, data["mods"], data["omics"], data["log_deg"],
                           list(range(N)), si, rwr_arr, m2_arr)
    X_locked_s = StandardScaler().fit(X_locked[data["train_idx"]]).transform(X_locked).astype(np.float32)

    for model_cls, tag in [(GCNModel, "GCN"), (GATModel, "GAT")]:
        try:
            r, sc = run_gnn_method(model_cls, f"{tag} [{len(locked_feats)}feat-locked]",
                                    X_locked_s, data["edge_index"], data)
            all_results.append(r); all_scores[r["method"]] = sc
        except Exception as e:
            import traceback; print(f"  ⚠  {tag} (locked) FAILED: {e}"); traceback.print_exc()

    try:
        r, sc = run_gnn_method(GCNModel, f"GCN [{data['X_full'].shape[1]}feat-full]",
                                data["X_full"], data["edge_index"], data)
        all_results.append(r); all_scores[r["method"]] = sc
    except Exception as e:
        import traceback; print(f"  ⚠  GCN (full) FAILED: {e}"); traceback.print_exc()

    # ── Comparison table: bootstrap CI + De Long vs MMSE-BC ──────────
    print(f"\n{'=' * 86}\n  FULL BENCHMARK — locked features: {locked_feats}\n"
          f"  AUPR: bootstrap 95% CI | AUROC: De Long (valid for AUROC only)\n{'=' * 86}")
    print(f"  {'Method':<26} {'AUPR':>7} {'AUPR 95% CI':>16} {'AUROC':>7} {'Fmax':>6}")
    print("  " + "─" * 70)

    rng_boot = np.random.default_rng(CFG["BASE_SEED"])
    labels = (y_test[test_idx] == 1.0).astype(int)
    ci_table, mmse_lo, mmse_hi = {}, 0.0, 0.0
    p_mmse = mmse_scores[test_idx].astype(np.float64)

    for r in all_results:
        name = r["method"]
        if name not in all_scores or np.isnan(r["test_aupr"]):
            print(f"  {name:<26} {'—':>7} {'—':>16} {'—':>7} {'—':>6}")
            continue
        p = all_scores[name][test_idx].astype(np.float64)
        lo, hi = bootstrap_ci_aupr(labels, p, rng_boot, n=500)
        ci_table[name] = (lo, hi)
        if "★" in name:
            mmse_lo, mmse_hi = lo, hi
        print(f"  {name:<26} {r['test_aupr']:>7.4f} [{lo:.3f},{hi:.3f}] "
              f"{r['test_auroc']:>7.4f} {r['fmax']:>6.4f}")

    print(f"\n  vs. MMSE-BC [{mmse_lo:.3f},{mmse_hi:.3f}]:")
    for r in all_results:
        name = r["method"]
        if "★" in name or name not in ci_table:
            continue
        lo, hi = ci_table[name]
        ov = lo < mmse_hi and hi > mmse_lo
        p = all_scores[name][test_idx].astype(np.float64)
        _, _, _, pd_ = delong_auroc(labels, p_mmse, p)
        print(f"    {name:<26} AUPR-CI: {'overlap' if ov else 'NON-overlap':<12} AUROC De Long p={pd_:.4f}")

    # ── Save results ──────────────────────────────────────────────
    df = pd.DataFrame(all_results)
    df.to_csv(os.path.join(CFG["out_dir"], "full_benchmark_results.csv"), index=False)
    with open(os.path.join(CFG["out_dir"], "full_benchmark_config.json"), "w") as f:
        json.dump({"locked_feats": locked_feats,
                    "runtime_min": round((time.time() - t0) / 60, 1)}, f, indent=2)

    print(f"\n  Saved → {CFG['out_dir']}full_benchmark_results.csv")
    print(f"  Saved → {CFG['out_dir']}full_benchmark_config.json")
    print(f"  Runtime: {round((time.time() - t0) / 60, 1)} min")
    return df


