# ONCOPLEX-style HGNN (Alotaibi et al. 2026 — current SOTA, supervised)
# ═══════════════════════════════════════════════════════════════════════

def _load_pathway_hyperedges(nodes, cache_dir):
    """Build incidence matrix H (N_genes × N_pathways) from MSigDB, cached.
    Falls back to degree-quintile grouping if MSigDB is unavailable."""
    cache_h = os.path.join(cache_dir, "hyperedge_H.npy")
    if os.path.exists(cache_h):
        H = np.load(cache_h)
        print(f"  📦 Hyperedge matrix from cache: {H.shape}")
        return H

    node_set = {str(n) for n in nodes}
    node2idx = {str(n): i for i, n in enumerate(nodes)}
    pathways = {}
    try:
        import gseapy as gp
        for lib in ["MSigDB_Hallmark_2020", "KEGG_2021_Human", "Reactome_2022"]:
            try:
                for pw_name, gene_list in gp.get_library(name=lib, organism="Human").items():
                    pathways[f"{lib}__{pw_name}"] = set(gene_list)
            except Exception:
                pass
    except ImportError:
        print("  [HGNN] gseapy not available — using fallback degree-quintile groups")

    if len(pathways) < 10:
        try:
            G_tmp = nx.read_gml(CFG["gml_path"])
            deg_arr = np.array([dict(G_tmp.degree()).get(n, 0) for n in nodes])
            for q in range(20):
                lo, hi = np.percentile(deg_arr, q * 5), np.percentile(deg_arr, (q + 1) * 5)
                members = {str(nodes[i]) for i in range(len(nodes)) if lo <= deg_arr[i] <= hi}
                if members:
                    pathways[f"DegGroup_{q}"] = members
        except Exception as e:
            print(f"  [HGNN] Fallback failed: {e}")

    pw_valid = [(name, g & node_set) for name, g in pathways.items() if 3 <= len(g & node_set) <= 500]
    if not pw_valid:
        pw_valid = [(f"Gene_{i}", {str(nodes[i])}) for i in range(min(len(nodes), 200))]

    P = len(pw_valid)
    H = np.zeros((len(nodes), P), dtype=np.float32)
    for j, (_, genes) in enumerate(pw_valid):
        for g in genes:
            if g in node2idx:
                H[node2idx[g], j] = 1.0
    np.save(cache_h, H)
    print(f"  [HGNN] {P} valid pathways, H={H.shape}  nnz={int(H.sum()):,}")
    return H


class HGNNLayer(nn.Module):
    """X' = D_v^{-1} H W D_e^{-1} H^T X Θ  (Feng et al. 2019, AAAI)."""
    def __init__(self, in_d, out_d, dropout=0.5):
        super().__init__()
        self.theta = nn.Linear(in_d, out_d, bias=False)
        self.bn = nn.BatchNorm1d(out_d)
        self.drop = nn.Dropout(dropout)
        nn.init.xavier_uniform_(self.theta.weight)

    def forward(self, x, H, D_v_inv, W_D_e_inv):
        Tx = self.theta(x)
        out = D_v_inv.unsqueeze(1) * (H @ (W_D_e_inv.unsqueeze(1) * (H.t() @ Tx)))
        return self.drop(F.elu(self.bn(out)))


class ONCOPLEX_HGNN(nn.Module):
    def __init__(self, in_d, hidden=256, dropout=0.5):
        super().__init__()
        self.hgnn1 = HGNNLayer(in_d, hidden, dropout)
        self.hgnn2 = HGNNLayer(hidden, hidden // 2, dropout)
        self.head = nn.Sequential(nn.Linear(hidden // 2, hidden // 4), nn.ELU(),
                                   nn.Dropout(dropout), nn.Linear(hidden // 4, 1))

    def forward(self, x, H, D_v_inv, W_D_e_inv):
        h = self.hgnn1(x, H, D_v_inv, W_D_e_inv)
        h = self.hgnn2(h, H, D_v_inv, W_D_e_inv)
        return self.head(h).squeeze(-1)


def run_oncoplex(data):
    """
    Supervised HGNN baseline (current SOTA, Jan 2026). Uses confirmed negatives
    as hard labels — strictly easier setup than MMSE-BC's PU learning, noted
    for fairness rather than hidden.
    """
    print("\n── ONCOPLEX-style HGNN (Alotaibi et al. 2026) ───────────────")
    print("   ⚠  Supervised (uses confirmed negatives) — MMSE-BC is PU learning, no negatives")

    H_np = _load_pathway_hyperedges(data["nodes"], CFG["ppi_cache"])
    H = torch.tensor(H_np, dtype=torch.float32, device=DEVICE)
    d_v = H.sum(dim=1).clamp(min=1.0); D_v_inv = 1.0 / d_v
    d_e = H.sum(dim=0).clamp(min=1.0); W_D_e_inv = 1.0 / (d_e * d_e)

    X_t = torch.tensor(data["X_full"], device=DEVICE)
    y_sup = np.zeros(data["N"], np.float32)
    y_sup[data["hp_train"]] = 1.0
    y_sup[data["neg_train"]] = 0.0
    y_t = torch.tensor(y_sup, device=DEVICE)
    train_idx, test_idx, y_test = data["train_idx"], data["test_idx"], data["y_test"]
    y_bin_tr = (y_sup[train_idx] == 1).astype(int)
    n_pos, n_neg = int(y_bin_tr.sum()), len(train_idx) - int(y_bin_tr.sum())

    all_scores = []
    for rep in range(CFG["n_repeats"]):
        try:
            tr_sub, val_sub = train_test_split(train_idx, test_size=0.10,
                                                stratify=y_bin_tr, random_state=42 + rep)
        except ValueError:
            tr_sub, val_sub = train_test_split(train_idx, test_size=0.10, random_state=42 + rep)
        tr_t = torch.tensor(tr_sub, dtype=torch.long, device=DEVICE)
        val_t = torch.tensor(val_sub, dtype=torch.long, device=DEVICE)
        pw = torch.tensor([n_neg / max(n_pos, 1)], device=DEVICE)

        model = ONCOPLEX_HGNN(X_t.shape[1]).to(DEVICE)
        opt = torch.optim.Adam(model.parameters(), lr=1e-3, weight_decay=5e-4)
        sched = torch.optim.lr_scheduler.CosineAnnealingLR(opt, T_max=CFG["epochs"], eta_min=1e-5)
        val_labels = (y_sup[val_sub] == 1.0).astype(float)
        best_aupr, best_wts, counter = 0.0, {}, 0

        for ep in range(CFG["epochs"]):
            model.train(); opt.zero_grad()
            logits = model(X_t, H, D_v_inv, W_D_e_inv)
            loss = F.binary_cross_entropy_with_logits(logits[tr_t], y_t[tr_t], pos_weight=pw)
            loss.backward()
            torch.nn.utils.clip_grad_norm_(model.parameters(), 1.0)
            opt.step(); sched.step()

            if (ep + 1) % 5 == 0:
                model.eval()
                with torch.no_grad():
                    vp = torch.sigmoid(model(X_t, H, D_v_inv, W_D_e_inv)[val_t]).cpu().numpy()
                if val_labels.sum() >= 1 and (val_labels == 0).sum() >= 1:
                    va = average_precision_score(val_labels, vp)
                    if va > best_aupr:
                        best_aupr, counter = va, 0
                        best_wts = {k: v.cpu().clone() for k, v in model.state_dict().items()}
                    else:
                        counter += 5
                if counter >= CFG["patience"]:
                    break

        if best_wts:
            model.load_state_dict(best_wts)
        model.eval()
        with torch.no_grad():
            all_scores.append(torch.sigmoid(model(X_t, H, D_v_inv, W_D_e_inv)).cpu().numpy().astype(np.float32))
        del model; gc.collect()
        if torch.cuda.is_available():
            torch.cuda.empty_cache()

    mean_scores = np.mean(np.stack(all_scores), axis=0)
    result = evaluate(mean_scores, y_test, test_idx, "ONCOPLEX_HGNN")
    print(f"  AUPR={result['test_aupr']:.4f}  AUROC={result['test_auroc']:.4f}  "
          f"Fmax={result['fmax']:.4f}  (mean of {len(all_scores)} reps)")
    return result, mean_scores


