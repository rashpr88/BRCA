def _ppi_cache_hash(nodes):
    c = CFG
    key = (f"n2v{c['n2v_dim']}_p{c['n2v_p']}_q{c['n2v_q']}_wl{c['n2v_walk_length']}_"
           f"wpn{c['n2v_walks_per_node']}_ep{c['n2v_epochs']}_rwr{c['rwr_dim']}_"
           f"a{c['rwr_alpha']}_T{c['rwr_T']}_netmf{c['netmf_dim']}_w{c['netmf_window']}_"
           f"N{len(nodes)}_n0{str(nodes[0])}_nN{str(nodes[-1])}")
    return hashlib.md5(key.encode()).hexdigest()[:12]


def _load_ppi_feature_stack(G, nodes):
    """struct(6) + N2V(128) + RWR-PPMI(64) + NetMF(64) = 262 dims, cached."""
    h = _ppi_cache_hash(nodes)

    def _try(tag):
        p = os.path.join(CFG["ppi_cache"], f"ppi_{tag}_{h}.npy")
        return np.load(p) if os.path.exists(p) else None

    struct_f = _try("struct")
    if struct_f is None:
        deg, clust = dict(G.degree()), nx.clustering(G)
        btwn = nx.betweenness_centrality(G, k=500, normalized=True, seed=42)
        struct_f = np.array([
            [deg[n], np.log1p(deg[n]), clust[n], btwn[n],
             np.mean([deg[nb] for nb in G.neighbors(n)] or [0]),
             np.max([deg[nb] for nb in G.neighbors(n)] or [0])]
            for n in nodes], dtype=np.float32)

    n2v_f = _try("n2v")
    if n2v_f is None:
        print("  ⚠  N2V cache miss — using random init (run main pipeline once to cache)")
        n2v_f = np.random.RandomState(42).randn(len(nodes), CFG["n2v_dim"]).astype(np.float32)

    rwr_f = _try("rwr") if _try("rwr") is not None else np.zeros((len(nodes), 64), np.float32)
    netmf_f = _try("netmf") if _try("netmf") is not None else np.zeros((len(nodes), 64), np.float32)

    ppi_X = np.hstack([struct_f, n2v_f, rwr_f, netmf_f]).astype(np.float32)
    return ppi_X, n2v_f.astype(np.float32)


def load_data() -> dict:
    """
    Load graph + all feature modalities + carve the fixed test split.
    Mirrors benchmark.py exactly, plus loads "seq" (ProtT5) embeddings
    and omics (mut/cna/expr) needed for the engineered/locked features.
    """
    print(f"Device: {DEVICE}\n📂 Loading graph…")
    G = nx.read_gml(CFG["gml_path"])
    nodes = list(G.nodes()); N = len(nodes)
    g2i = {n: i for i, n in enumerate(nodes)}
    print(f"  {N} nodes | {G.number_of_edges()} edges")

    # ── Labels ────────────────────────────────────────────────────
    df = pd.read_excel(CFG["label_path"], sheet_name="Genes")
    hp_names = set(df["Genes"].dropna().astype(str))
    try:
        neg_names = set(df["Negatives"].dropna().astype(str))
    except KeyError:
        neg_names = set()

    y = np.zeros(N, np.float32)
    for i, n in enumerate(nodes):
        if str(n) in hp_names:
            y[i] = 1.0
    hp_idx = np.where(y == 1.0)[0]
    neg_idx = np.array([i for i, n in enumerate(nodes) if str(n) in neg_names], np.int64)
    unlabeled_idx = np.setdiff1d(np.where(y == 0.0)[0], neg_idx)
    print(f"  HP={len(hp_idx)}  NEG={len(neg_idx)}  U={len(unlabeled_idx)}")

    # ── Fixed test split ─────────────────────────────────────────
    hp_perm = np.random.RandomState(CFG["HP_TEST_SEED"]).permutation(hp_idx)
    n_hp_test = max(1, int(CFG["HP_TEST_FRAC"] * len(hp_idx)))
    hp_test, hp_train = hp_perm[:n_hp_test], hp_perm[n_hp_test:]

    u_perm = np.random.RandomState(CFG["U_TEST_SEED"]).permutation(unlabeled_idx)
    n_u_test = min(n_hp_test * CFG["U_TEST_RATIO"], len(unlabeled_idx) // 2)
    u_test = u_perm[:n_u_test]

    if len(neg_idx) > 0:
        neg_perm = np.random.RandomState(CFG["NEG_TEST_SEED"]).permutation(neg_idx)
        n_neg_test = max(1, int(CFG["HP_TEST_FRAC"] * len(neg_idx)))
        neg_test, neg_train = neg_perm[:n_neg_test], neg_perm[n_neg_test:]
    else:
        neg_test = neg_train = np.array([], np.int64)

    test_idx = np.unique(np.concatenate([hp_test, u_test, neg_test]))
    y_test = np.zeros(N, np.float32); y_test[hp_test] = 1.0   # positives = HP test only

    excluded = set(test_idx.tolist()) | set(neg_idx.tolist())
    u_pool = np.array([i for i in unlabeled_idx if i not in excluded])
    n_u_tr = min(len(hp_train) * 15, 5000, len(u_pool))
    u_train = np.random.RandomState(42).choice(u_pool, size=n_u_tr, replace=False)
    train_idx = np.unique(np.concatenate([hp_train, u_train, neg_train]))

    print(f"  HP test={len(hp_test)} (train={len(hp_train)}) | U test={len(u_test)} | "
          f"NEG test={len(neg_test)} | Test={len(test_idx)} | Train={len(train_idx)}")

    # ── Embeddings: seq (ProtT5) + struct + go ──────────────────────
    print("📂 Loading modality embeddings…")
    mods = {}
    with h5py.File(CFG["h5_path"], "r") as f:
        for key in ["seq", "struct", "go"]:
            if key not in f:
                continue
            avail = set(f[key].keys())
            s0 = next(iter(avail))
            d = np.asarray(f[key][s0][()]).flatten().shape[0]
            M = np.zeros((N, d), np.float32)
            for i, n in enumerate(nodes):
                if str(n) in avail:
                    M[i] = np.asarray(f[key][str(n)][()]).flatten()
            M = StandardScaler().fit_transform(M).astype(np.float32)
            mods[key] = normalize(M, axis=1).astype(np.float32)
    print("  " + ", ".join(f"{k}:{v.shape[1]}d" for k, v in mods.items()))

    # ── Omics: mut/cna/expr (global z-score, scalars) ──────────────
    omics = {}
    g2i_str = {str(n): i for n, i in g2i.items()}
    raw = {k: np.zeros(N, np.float32) for k in ["mut", "cna", "expr"]}
    km = {"mut_freq": "mut", "cna_freq": "cna", "expr_zscore": "expr"}
    if os.path.exists(CFG["omics_csv"]):
        with open(CFG["omics_csv"]) as f:
            for row in csv.DictReader(f):
                if row["gene"] in g2i_str:
                    i = g2i_str[row["gene"]]
                    for col, key in km.items():
                        if col in row:
                            raw[key][i] = float(row[col])
    for k, v in raw.items():
        mu, sd = v.mean(), v.std()
        omics[k] = ((v - mu) / max(sd, 1e-9)).astype(np.float32)

    # ── Full PPI feature stack (struct+N2V+RWR-PPMI+NetMF), cached ──
    print("📂 Building PPI feature stack…")
    ppi_X, n2v_X = _load_ppi_feature_stack(G, nodes)

    def _scale(X):
        sc = StandardScaler().fit(X[train_idx])
        return sc.transform(X).astype(np.float32)

    struct_s, go_s, ppi_s, n2v_s = (_scale(mods.get("struct", np.zeros((N, 1), np.float32))),
                                     _scale(mods.get("go", np.zeros((N, 1), np.float32))),
                                     _scale(ppi_X), _scale(n2v_X))
    X_full = np.hstack([struct_s, go_s, ppi_s]).astype(np.float32)

    # ── Graph structures: sparse adjacency + row-normalized walk matrix ─
    A = nx.to_scipy_sparse_array(G, nodelist=nodes, weight="weight", format="csr", dtype=np.float64)
    deg = np.asarray(A.sum(1)).flatten(); deg_safe = np.where(deg == 0, 1.0, deg)
    W = (sp.diags(1.0 / deg_safe) @ A).tocsr()
    log_deg = np.log1p(deg).astype(np.float32)

    rows, cols = [], []
    for u, v in G.edges():
        i, j = g2i[u], g2i[v]
        rows += [i, j]; cols += [j, i]
    edge_index = torch.tensor([rows, cols], dtype=torch.long)

    return dict(
        G=G, nodes=nodes, N=N, g2i=g2i,
        y=y, y_test=y_test,
        hp_train=hp_train, hp_test=hp_test,
        neg_idx=neg_idx, neg_train=neg_train, neg_test=neg_test,
        train_idx=train_idx, test_idx=test_idx,
        mods=mods, omics=omics, log_deg=log_deg,
        A=A, W=W, deg=deg, edge_index=edge_index,
        X_full=X_full, X_n2v=n2v_s,
    )


# ═══════════════════════════════════════════════════════════════════════
# CLASSICAL TOPOLOGY METHODS (no training — purely graph-based)
# ═══════════════════════════════════════════════════════════════════════

def rwr_fn(W, N, seeds, alpha=CFG["RWR_ALPHA"], n_iter=CFG["RWR_ITER"]):
    s = np.zeros(N, np.float32); s[seeds] = 1. / len(seeds); r = s.copy()
    for _ in range(n_iter):
        r = (1 - alpha) * (W.T @ r) + alpha * s
    return r


def markov2_fn(W, N, seeds):
    s = np.zeros(N, np.float32); s[seeds] = 1. / len(seeds)
    return (W.T @ (W.T @ s)).astype(np.float32)


def mv_scores_fn(A, N, hp_set):
    """Direct-neighbor majority-vote score: count of HP neighbors."""
    sm = np.zeros(N, bool); sm[list(hp_set)] = True
    return np.array([sm[A.indices[A.indptr[i]:A.indptr[i + 1]]].sum()
                      for i in range(N)], np.float32)


def hishigaki_fn(A, N, hp_set):
    """Hishigaki et al. 2001 — hypergeometric enrichment of HP neighbors."""
    deg = np.asarray(A.sum(1)).flatten().astype(int); n_hp = len(hp_set)
    s = np.zeros(N, np.float64)
    for i in range(N):
        if i in hp_set:
            continue
        nbrs = A.indices[A.indptr[i]:A.indptr[i + 1]]
        ki, xi = int(deg[i]), int(sum(1 for nb in nbrs if nb in hp_set))
        if ki == 0 or xi == 0:
            continue
        s[i] = -np.log10(max(hypergeom.sf(xi - 1, N, n_hp, ki), 1e-300))
    return s


def niapu_fn(W, A, N, hp_set, alpha=0.85, beta=0.5):
    """NIAPU — blend of global RWR and local HP-weighted neighbor score."""
    r = rwr_fn(W, N, list(hp_set), alpha=beta)
    deg = np.asarray(A.sum(1)).flatten(); deg[deg == 0] = 1.0
    local = np.zeros(N, np.float64)
    for i in range(N):
        nbrs = A.indices[A.indptr[i]:A.indptr[i + 1]]
        local[i] = sum(float(r[nb]) for nb in nbrs if nb in hp_set) / deg[i]
    n01 = lambda x: (x - x.min()) / (x.max() - x.min() + 1e-12)
    s = alpha * n01(r.astype(np.float64)) + (1 - alpha) * n01(local)
    for i in hp_set:
        s[i] = 0.0
    return s


def local_nbr_fn(G, nodes, hp_set):
    """Degree-normalized HP-neighbor heuristic — upper bound for 'trivial' topology."""
    deg = dict(G.degree())
    scores = np.array([
        sum(1 for nb in G.neighbors(n) if nb in hp_set) / max(np.sqrt(deg[n]), 1.0)
        for n in nodes], np.float32)
    if scores.max() > 0:
        scores = (scores - scores.min()) / (scores.max() - scores.min())
    return scores


