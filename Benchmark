def run_n2v_xgb(data):
    """Node2Vec embeddings + XGBoost — ablates the GNN (same embeddings, no message passing)."""
    if not _HAS_XGB:
        print("\n── N2V+XGB — SKIPPED (xgboost not installed)")
        return None
    print("\n── N2V + XGBoost ─────────────────────────────────────────")
    X, y_bin = data["X_n2v"], (data["y"] == 1.0).astype(int)
    train_idx = data["train_idx"]
    n_pos = int(y_bin[train_idx].sum()); n_neg = len(train_idx) - n_pos

    all_scores = []
    for rep in range(CFG["n_repeats"]):
        try:
            tr_sub, val_sub = train_test_split(train_idx, test_size=0.15,
                                                stratify=y_bin[train_idx], random_state=rep)
        except ValueError:
            tr_sub, val_sub = train_test_split(train_idx, test_size=0.15, random_state=rep)
        model = xgb.XGBClassifier(
            n_estimators=500, max_depth=4, learning_rate=0.05,
            subsample=0.8, colsample_bytree=0.8, min_child_weight=3,
            scale_pos_weight=n_neg / max(n_pos, 1), eval_metric="aucpr",
            early_stopping_rounds=20, random_state=rep, n_jobs=4)
        model.fit(X[tr_sub], y_bin[tr_sub], eval_set=[(X[val_sub], y_bin[val_sub])], verbose=False)
        all_scores.append(model.predict_proba(X)[:, 1].astype(np.float32))

    mean_scores = np.mean(np.stack(all_scores), axis=0)
    result = evaluate(mean_scores, data["y_test"], data["test_idx"], "N2V_XGB")
    print(f"  AUPR={result['test_aupr']:.4f}  AUROC={result['test_auroc']:.4f}  Fmax={result['fmax']:.4f}")
    return result, mean_scores


def run_rf_feat_only(data):
    """Random Forest on struct+GO features only — ablates graph topology entirely."""
    print("\n── RF Feature-Only (no graph) ──────────────────────────────")
    X = np.hstack([data["mods"].get("struct", np.zeros((data["N"], 1))),
                    data["mods"].get("go", np.zeros((data["N"], 1)))])
    y_bin, train_idx = (data["y"] == 1.0).astype(int), data["train_idx"]

    all_scores = []
    for rep in range(CFG["n_repeats"]):
        model = RandomForestClassifier(n_estimators=500, min_samples_leaf=2,
                                        class_weight="balanced", n_jobs=4, random_state=rep)
        model.fit(X[train_idx], y_bin[train_idx])
        all_scores.append(model.predict_proba(X)[:, 1].astype(np.float32))

    mean_scores = np.mean(np.stack(all_scores), axis=0)
    result = evaluate(mean_scores, data["y_test"], data["test_idx"], "RF_FeatOnly")
    print(f"  AUPR={result['test_aupr']:.4f}  AUROC={result['test_auroc']:.4f}  Fmax={result['fmax']:.4f}")
    return result, mean_scores


