# EVALUATION
# ═══════════════════════════════════════════════════════════════════════

def fmax_score(y, p):
    pr, rc, _ = precision_recall_curve(y, p)
    return float((2 * pr * rc / (pr + rc + 1e-9)).max())


def evaluate(scores, y_test, test_idx, method):
    labels = (y_test[test_idx] == 1.0).astype(int)
    probs = scores[test_idx]
    if labels.sum() < 1 or (labels == 0).sum() < 1:
        return dict(method=method, test_aupr=np.nan, test_auroc=np.nan, fmax=np.nan)
    return dict(method=method,
                test_aupr=round(average_precision_score(labels, probs), 4),
                test_auroc=round(roc_auc_score(labels, probs), 4),
                fmax=round(fmax_score(labels, probs), 4))


def bootstrap_ci_aupr(y, p, rng, n=500):
    vals = []
    for _ in range(n):
        ix = rng.integers(0, len(y), len(y))
        if y[ix].sum() >= 1 and (y[ix] == 0).sum() >= 1:
            vals.append(average_precision_score(y[ix], p[ix]))
    return tuple(np.percentile(vals, [2.5, 97.5]))


def delong_auroc(y, sa, sb):
    """De Long (1988) paired AUROC test — valid for AUROC only, not AUPR."""
    pm, nm = y == 1, y == 0
    spa, sna, spb, snb = sa[pm], sa[nm], sb[pm], sb[nm]
    m, n = len(spa), len(sna)
    if m == 0 or n == 0:
        return np.nan, np.nan, np.nan, np.nan

    def place(sp, sn):
        m_, n_ = len(sp), len(sn)
        v10 = np.array([((sn < s).sum() + 0.5 * (sn == s).sum()) / n_ for s in sp])
        v01 = np.array([((sp > s).sum() + 0.5 * (sp == s).sum()) / m_ for s in sn])
        return v10, v01

    auc_a, auc_b = roc_auc_score(y, sa), roc_auc_score(y, sb)
    v10a, v01a = place(spa, sna); v10b, v01b = place(spb, snb)
    s10aa, s01aa = np.var(v10a, ddof=1) / m, np.var(v01a, ddof=1) / n
    s10bb, s01bb = np.var(v10b, ddof=1) / m, np.var(v01b, ddof=1) / n
    s10ab = np.cov(v10a, v10b, ddof=1)[0, 1] / m
    s01ab = np.cov(v01a, v01b, ddof=1)[0, 1] / n
    vd = (s10aa + s01aa) + (s10bb + s01bb) - 2 * (s10ab + s01ab)
    if vd <= 0:
        return auc_a, auc_b, 0.0, 1.0
    z = (auc_a - auc_b) / np.sqrt(vd)
    return auc_a, auc_b, z, float(2 * (1 - norm.cdf(abs(z))))


