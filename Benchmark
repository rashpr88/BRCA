# GNNs — EMOGI-style GCN, CancerGATE-style GAT (shared training loop)
# ═══════════════════════════════════════════════════════════════════════

class GCNModel(nn.Module):
    """EMOGI-style 2-layer GCN. PyG GCNConv (self-loops, symmetric norm) or linear fallback."""
    def __init__(self, in_d, hidden=128, dropout=CFG["dropout"]):
        super().__init__()
        self.drop = nn.Dropout(dropout)
        if _HAS_PYG:
            self.c1 = GCNConv(in_d, hidden, add_self_loops=True, normalize=True)
            self.c2 = GCNConv(hidden, hidden // 2, add_self_loops=True, normalize=True)
            self.head = nn.Linear(hidden // 2, 1)
        else:
            self.head = nn.Linear(in_d, 1)   # no-graph fallback

    def forward(self, x, edge_index):
        if not _HAS_PYG:
            return self.head(x).squeeze(-1)
        h = self.drop(F.relu(self.c1(x, edge_index)))
        h = self.drop(F.relu(self.c2(h, edge_index)))
        return self.head(h).squeeze(-1)


class GATModel(nn.Module):
    """CancerGATE-style 2-layer GAT. PyG GATConv (8 heads → 1 head) or linear fallback."""
    def __init__(self, in_d, hidden=64, heads=8, dropout=CFG["dropout"]):
        super().__init__()
        self.drop = nn.Dropout(dropout)
        if _HAS_PYG:
            self.g1 = GATConv(in_d, hidden, heads=heads, dropout=dropout, add_self_loops=True)
            self.g2 = GATConv(hidden * heads, hidden, heads=1, concat=False,
                               dropout=dropout, add_self_loops=True)
            self.head = nn.Linear(hidden, 1)
        else:
            self.head = nn.Linear(in_d, 1)

    def forward(self, x, edge_index):
        if not _HAS_PYG:
            return self.head(x).squeeze(-1)
        h = self.drop(F.elu(self.g1(x, edge_index)))
        h = self.drop(F.elu(self.g2(h, edge_index)))
        return self.head(h).squeeze(-1)


def train_gnn(model, X_t, y_t, train_idx_t, val_idx_t, edge_index,
              epochs=CFG["epochs"], patience=CFG["patience"], lr=CFG["lr"], weight_decay=5e-4):
    """Full-graph transductive training with early stopping on val AUPR. No test leakage."""
    opt = torch.optim.Adam(model.parameters(), lr=lr, weight_decay=weight_decay)
    sched = torch.optim.lr_scheduler.CosineAnnealingLR(opt, T_max=epochs, eta_min=lr * 0.05)
    n_pos = int((y_t[train_idx_t] == 1.0).sum().item())
    n_neg = int((y_t[train_idx_t] == 0.0).sum().item())
    pw = torch.tensor([n_neg / max(n_pos, 1)], device=DEVICE)

    val_labels = (y_t[val_idx_t].cpu().numpy() == 1.0).astype(float)
    best_aupr, best_wts, counter = 0.0, None, 0

    for ep in range(epochs):
        model.train(); opt.zero_grad()
        logits = model(X_t, edge_index)
        loss = F.binary_cross_entropy_with_logits(logits[train_idx_t], y_t[train_idx_t], pos_weight=pw)
        loss.backward()
        torch.nn.utils.clip_grad_norm_(model.parameters(), 1.0)
        opt.step(); sched.step()

        if (ep + 1) % 5 == 0 and len(val_labels) > 0:
            model.eval()
            with torch.no_grad():
                vp = torch.sigmoid(model(X_t, edge_index)[val_idx_t]).cpu().numpy()
            if val_labels.sum() >= 1 and (val_labels == 0).sum() >= 1:
                va = average_precision_score(val_labels, vp)
                if va > best_aupr:
                    best_aupr, counter = va, 0
                    best_wts = {k: v.cpu().clone() for k, v in model.state_dict().items()}
                else:
                    counter += 5
            if counter >= patience:
                break

    if best_wts:
        model.load_state_dict(best_wts)
    model.eval()
    return model


def run_gnn_method(model_cls, name, X, edge_index, data, reps=CFG["n_repeats"], lr=CFG["lr"]):
    """Repeated-fit GNN runner. Each rep gets an independent train/val split (no test leakage)."""
    print(f"\n── {name} ────────────────────────────────────────────────")
    X_t = torch.tensor(X, dtype=torch.float32, device=DEVICE)
    y_t = torch.tensor(data["y"], device=DEVICE)
    ei = edge_index.to(DEVICE)
    train_idx, y_bin = data["train_idx"], (data["y"] == 1.0).astype(int)

    all_scores = []
    for rep in range(reps):
        try:
            tr_sub, val_sub = train_test_split(train_idx, test_size=0.10,
                                                stratify=y_bin[train_idx], random_state=42 + rep)
        except ValueError:
            tr_sub, val_sub = train_test_split(train_idx, test_size=0.10, random_state=42 + rep)
        tr_t = torch.tensor(tr_sub, dtype=torch.long, device=DEVICE)
        val_t = torch.tensor(val_sub, dtype=torch.long, device=DEVICE)

        model = model_cls(X.shape[1]).to(DEVICE)
        train_gnn(model, X_t, y_t, tr_t, val_t, ei, lr=lr)
        with torch.no_grad():
            all_scores.append(torch.sigmoid(model(X_t, ei)).cpu().numpy().astype(np.float32))
        del model; gc.collect()
        if torch.cuda.is_available():
            torch.cuda.empty_cache()

    mean_scores = np.mean(np.stack(all_scores), axis=0)
    result = evaluate(mean_scores, data["y_test"], data["test_idx"], name)
    print(f"  AUPR={result['test_aupr']:.4f}  AUROC={result['test_auroc']:.4f}  "
          f"Fmax={result['fmax']:.4f}  (mean of {reps} reps)")
    return result, mean_scores


