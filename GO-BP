# Load UniProt IDs with structures

with open("uniprot_ids_with_structure.json", "r") as f:
    uniprot_ids = json.load(f)

print(f"Total proteins with structure: {len(uniprot_ids)}")

# Function: Fetch GO BP IDs from QuickGO

def get_quickgo_go_bp_ids(uniprot_id):
    url = "https://www.ebi.ac.uk/QuickGO/services/annotation/search"
    params = {
        "geneProductId": f"UniProtKB:{uniprot_id}",
        "aspect": "biological_process,molecular_function,cellular_component",
        "limit": 200  # QuickGO max
    }
    headers = {"Accept": "application/json"}

    try:
        r = requests.get(url, params=params, headers=headers, timeout=10)
        if r.status_code != 200:
            print(f"{uniprot_id} -> Error {r.status_code}")
            return []
        data = r.json()
    except Exception as e:
        print(f"{uniprot_id} -> Exception: {e}")
        return []

    go_bp_ids = []
    for item in data.get("results", []):
        evidence = item.get("evidenceCode")
        if evidence not in ("IEA", "ECO:0007322"):
            go_bp_ids.append(item.get("goId"))

    return list(set(go_bp_ids))  # Remove duplicates

# Fetch GO BP for all proteins
all_go_bp = {}
for i, uid in enumerate(uniprot_ids, 1):
    go_ids = get_quickgo_go_bp_ids(uid)
    all_go_bp[uid] = go_ids
    print(f"[{i}/{len(uniprot_ids)}] {uid}: {len(go_ids)} BP terms")
    time.sleep(0.2)  # polite delay

# Save to JSON
with open(go_bp_output_file, "w") as f:
    json.dump(all_go_bp, f, indent=2)

print(f"\nGO BP IDs saved for {len(all_go_bp)} proteins -> {go_bp_output_file}")

# Load UniProt → GO-BP mapping

go_bp_file = "uniprot_go_all.json"

with open(go_bp_file, "r") as f:
    uniprot_go_bp = json.load(f)

# Count proteins with non-empty GO-BP annotations
proteins_with_go = sum(1 for go_terms in uniprot_go_bp.values() if go_terms)

print(f"Total proteins: {len(uniprot_go_bp)}")
print(f"Proteins with GO-BP annotations: {proteins_with_go}")
print(f"Proteins without GO-BP annotations: {len(uniprot_go_bp) - proteins_with_go}")
print(f"Percentage with annotations: {proteins_with_go/len(uniprot_go_bp)*100:.2f}%")


#  Count GO-BP term frequencies
go_counter = Counter()

for go_terms in uniprot_go_bp.values():
    unique_terms = set(go_terms)
    go_counter.update(unique_terms)

print(f"Total unique GO-BP terms: {len(go_counter)}")


# Keep GO-BP terms occurring ≥ 500 times
MIN_COUNT = 500

selected_go_terms = sorted([
    go for go, count in go_counter.items()
    if count >= MIN_COUNT
])

print(f"GO-BP terms occurring ≥ {MIN_COUNT}: {len(selected_go_terms)}")

# Build GO-BP index
go_to_index = {go: idx for idx, go in enumerate(selected_go_terms)}
num_go_terms = len(go_to_index)

print(f"Final GO-BP one-hot dimension: {num_go_terms}")

# One-hot encode per UniProt ID
import numpy as np

uniprot_go_onehot = {}

for uniprot_id, go_terms in uniprot_go_bp.items():
    vector = np.zeros(num_go_terms, dtype=int)

    for go in set(go_terms):
        if go in go_to_index:
            vector[go_to_index[go]] = 1

    uniprot_go_onehot[uniprot_id] = vector.tolist()

go_vocab_file = "go_bp_vocab.json"

with open(go_vocab_file, "w") as f:
    json.dump(go_to_index, f, indent=2)

onehot_file = "uniprot_go_bp_binary.json"

with open(onehot_file, "w") as f:
    json.dump(uniprot_go_onehot, f)

print("Saved GO-BP one-hot encodings")


