# Build CPDB gene universe
cpdb_gene_set = set()
for g1, g2 in cpdb_edges:
    cpdb_gene_set.add(g1); cpdb_gene_set.add(g2)
cpdb_genes = sorted(cpdb_gene_set)
str_gene_set = set(str_genes)

print(f"\n  CPDB:           {len(cpdb_genes)} genes  {len(cpdb_edges)} edges")
print(f"  STRING:         {len(str_gene_set)} genes  {len(str_edges)} edges")

# Intersection and union
common_genes = str_gene_set & cpdb_gene_set
intersect_edges = {e for e in str_edges & cpdb_edges
                   if e[0] in common_genes and e[1] in common_genes}
union_genes = str_gene_set | cpdb_gene_set
union_edges = str_edges | cpdb_edges

print(f"  STRING∩CPDB:    {len(common_genes)} genes  {len(intersect_edges)} edges")
print(f"  STRING∪CPDB:    {len(union_genes)} genes  {len(union_edges)} edges")

