def parse_cpdb_ppi(path, min_sources=2, max_complex=10):
    """
    Parse ConsensusPathDB_human_PPI.

    Column layout (tab-separated, no header):
      0: source_databases          (comma-sep)
      1: interaction_publications  (comma-sep PMIDs)
      2: uniprot_entry             (comma-sep)
      3: uniprot_id                (comma-sep)
      4: genename                  (comma-sep)  ← USE THIS
      5: hgnc_id
      6: entrez_gene
      7: ensembl_gene
      8: interaction_confidence

    Filters:
      min_sources  ≥ 2   : exclude single-database entries (e.g. Reactome-only)
      max_complex  ≤ 10  : exclude large complexes (ribosome/proteasome/spliceosome)
                           which would generate thousands of spurious pairwise edges
    """
    edges      = set()
    n_total    = 0
    n_1gene    = 0
    n_low_src  = 0
    n_complex  = 0
    n_kept     = 0

    with open(path, encoding="utf-8") as f:
        for line in f:
            if line.startswith("#") or not line.strip():
                continue
            parts = line.rstrip("\n").split("\t")
            if len(parts) < 5:
                continue
            n_total += 1

            # Count source databases
            src_field = parts[0].strip()
            n_src = len([s for s in src_field.split(",") if s.strip()])
            if n_src < min_sources:
                n_low_src += 1
                continue

            # Parse gene names
            gene_field = parts[4].strip()
            if not gene_field:
                n_1gene += 1
                continue
            genes = [g.strip() for g in gene_field.split(",")
                     if g.strip() and g.strip() != "NA"]
            if len(genes) < 2:
                n_1gene += 1
                continue
            if len(genes) > max_complex:
                n_complex += 1
                continue

            # All pairwise combinations
            for g1, g2 in combinations(genes, 2):
                if g1 != g2:
                    edges.add(tuple(sorted([g1, g2])))
            n_kept += 1

    print(f"  CPDB PPI parser results:")
    print(f"    Total rows:              {n_total:>8,}")
    print(f"    Skipped (<{min_sources} sources):    {n_low_src:>8,}")
    print(f"    Skipped (1 gene):        {n_1gene:>8,}")
    print(f"    Skipped (>{max_complex} genes):     {n_complex:>8,}")
    print(f"    Rows used:               {n_kept:>8,}")
    print(f"    Unique pairwise edges:   {len(edges):>8,}")
    return edges

