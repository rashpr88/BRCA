        "z_score":           round(z_score.get(n, 0.0), 4),
        "participation_coef": round(P_score.get(n, 0.0), 4),
        # Network topology
        "degree_subnet":     int(G_sub.degree(n)),
        "degree_full_net":   int(G_union.degree(n)) if n in G_union else 0,
        # DEP evidence
        "is_DEP":            bool(dep.get("is_DEP", False)),
        "log2FC":            round(float(dep["log2FC"]), 3) if "log2FC" in dep else "",
