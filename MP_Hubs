# Subnetwork + Leiden + Hub cartography (De Silva 2025 exact)

print(f"\n[7/7] Subnetwork + Leiden + hub cartography (De Silva 2025)...")

# De Silva 2025 exact thresholds:
#   Z >= 1.5  → intra-modular hub  (used 1.5 not 2.5; 2.5 missed top hub)
#   PC > 0.5  → inter-modular hub
#   Min module size: 6 nodes
Z_THRESH     = 1.5
PC_THRESH    = 0.5
MIN_MOD_SIZE = 6
LEIDEN_GAMMA = 1.0   # Louvain-equivalent resolution

# ── Build subnetwork: DEP candidates + HPs ───────────────────────────
subnet_genes = t1_set | all_hp_names
present      = [g for g in subnet_genes if g in G_union]
G_sub        = G_union.subgraph(present).copy()
n_iso        = sum(1 for n in G_sub if G_sub.degree(n) == 0)
print(f"  Subnetwork: {G_sub.number_of_nodes()} nodes  "
      f"{G_sub.number_of_edges()} edges  ({n_iso} isolated)")

# ── Leiden community detection ────────────────────────────────────────
non_iso  = [n for n in G_sub if G_sub.degree(n) > 0]
iso_list = [n for n in G_sub if G_sub.degree(n) == 0]
nl       = list(non_iso); n2i_l = {n: i for i, n in enumerate(nl)}
edges_l  = [(n2i_l[u], n2i_l[v])
            for u, v in G_sub.subgraph(non_iso).edges()]
Gig      = ig.Graph(n=len(nl), edges=edges_l, directed=False)
Gig.vs["name"] = nl
part = leidenalg.find_partition(
    Gig, leidenalg.RBConfigurationVertexPartition,
    resolution_parameter=LEIDEN_GAMMA, seed=42)

raw_mod   = {nl[i]: int(m) for i, m in enumerate(part.membership)}
for g in iso_list: raw_mod[g] = -1
sizes     = Counter(raw_mod.values())

# Exclude modules with < 6 nodes (De Silva: < 6)
module_of = {n: (m if m >= 0 and sizes[m] >= MIN_MOD_SIZE else -1)
             for n, m in raw_mod.items()}
Q         = float(part.modularity)
n_mod     = len({v for v in module_of.values() if v >= 0})
print(f"  Leiden gamma={LEIDEN_GAMMA}: {n_mod} modules "
      f"(>={MIN_MOD_SIZE} nodes)  Q={Q:.4f}")

# ── Within-module Z-score (De Silva eq.10) ───────────────────────────
mod_groups = {}
for n, m in module_of.items():
    mod_groups.setdefault(m, []).append(n)

z_score = {}
for m, ns in mod_groups.items():
    if m < 0:
        for n in ns: z_score[n] = 0.0
        continue
    nset = set(ns)
    # ks_i = within-module degree
    kw   = {n: sum(1 for nb in G_sub.neighbors(n) if nb in nset) for n in ns}
    vals = np.array(list(kw.values()), dtype=float)
    if len(vals) <= 1 or vals.std() == 0:
        for n in ns: z_score[n] = 0.0
    else:
        mu_m, sd_m = vals.mean(), vals.std()
        for n in ns: z_score[n] = float((kw[n] - mu_m) / sd_m)

# ── Participation Coefficient (De Silva eq.11) ────────────────────────
# PC_i = 1 - sum_s( (k_si / k_i)^2 )
# k_i = total degree, k_si = edges to module s
P_score = {}
for n in G_sub.nodes():
    nbrs = list(G_sub.neighbors(n)); ki = len(nbrs)
    if ki == 0: P_score[n] = 0.0; continue
    cnt = {}
    for nb in nbrs:
        m = module_of.get(nb, -1); cnt[m] = cnt.get(m, 0) + 1
    P_score[n] = float(1.0 - sum((c/ki)**2 for c in cnt.values()))

# ── Hub classification (De Silva 2025 exact thresholds) ──────────────
# Z >= 1.5  AND  PC > 0.5  → inter-modular hub
# Z >= 1.5  AND  PC <= 0.5 → intra-modular hub
# Z < 1.5                  → non-hub
hub_class = {}
for n in G_sub.nodes():
    z = z_score.get(n, 0.0); P = P_score.get(n, 0.0)
    if z >= Z_THRESH:
        hub_class[n] = "INTER_HUB" if P > PC_THRESH else "INTRA_HUB"
    else:
        hub_class[n] = "NON_HUB"

n_inter = sum(1 for v in hub_class.values() if v == "INTER_HUB")
n_intra = sum(1 for v in hub_class.values() if v == "INTRA_HUB")
print(f"  Intra-modular hubs (Z>={Z_THRESH}, PC<={PC_THRESH}):  {n_intra}")
print(f"  Inter-modular hubs (Z>={Z_THRESH}, PC>{PC_THRESH}):   {n_inter}")
print(f"  Total hubs: {n_inter + n_intra}")

