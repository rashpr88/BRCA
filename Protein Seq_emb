import json
import torch
from transformers import T5Tokenizer, T5EncoderModel


# Config
fasta_file = "P_Seq.fasta"
output_json = "prott5_embeddings.json"
model_name = "Rostlab/prot_t5_xl_half_uniref50-enc"  # half-precision encoder
chunk_size = 512      # number of amino acids per chunk
overlap_size = 256    # overlap between consecutive chunks

device = torch.device("cuda" if torch.cuda.is_available() else "cpu")


# Load ProtT5 half-precision encoder
tokenizer = T5Tokenizer.from_pretrained(model_name, do_lower_case=False)
model = T5EncoderModel.from_pretrained(model_name, torch_dtype=torch.float16)
model.to(device)
model.eval()


# FASTA parser
def read_fasta(fasta_path):
    sequences = {}
    current_id = None
    current_seq = []

    with open(fasta_path, "r") as f:
        for line in f:
            line = line.strip()
            if line.startswith(">"):
                if current_id is not None:
                    sequences[current_id] = "".join(current_seq)
                current_id = line.split("|")[1]
                current_seq = []
            else:
                current_seq.append(line)
        if current_id is not None:
            sequences[current_id] = "".join(current_seq)

    return sequences


# Mean pooling function
def mean_pooling(hidden_states, attention_mask):
    mask = attention_mask.unsqueeze(-1).expand(hidden_states.size()).float()
    summed = torch.sum(hidden_states * mask, dim=1)
    counts = torch.clamp(mask.sum(dim=1), min=1e-9)
    return summed / counts


# Split sequence into overlapping chunks
def chunk_sequence_overlap(seq, chunk_size=512, overlap=256):
    chunks = []
    step = chunk_size - overlap
    for i in range(0, len(seq), step):
        chunks.append(seq[i:i + chunk_size])
    return chunks


# Generate embeddings
sequences = read_fasta(fasta_file)
embeddings = {}

for uniprot_id, seq in sequences.items():
    chunk_embs = []

    for chunk in chunk_sequence_overlap(seq, chunk_size, overlap_size):
        spaced_chunk = " ".join(list(chunk))
        encoded = tokenizer(
            spaced_chunk,
            return_tensors="pt",
            padding=True,
            truncation=True,
            max_length=chunk_size
        )
        encoded = {k: v.to(device) for k, v in encoded.items()}

        with torch.no_grad(), torch.cuda.amp.autocast():  # mixed precision
            outputs = model(**encoded)
            pooled = mean_pooling(outputs.last_hidden_state, encoded["attention_mask"])

        # Move chunk embedding to CPU and store
        chunk_embs.append(pooled.squeeze(0).cpu())

        # Clear GPU memory after each chunk
        if torch.cuda.is_available():
            torch.cuda.empty_cache()

    # Aggregate chunk embeddings (mean pooling over chunks)
    protein_emb = torch.mean(torch.stack(chunk_embs), dim=0)
    embeddings[uniprot_id] = protein_emb.tolist()

    print(f"Embedded {uniprot_id} | Dim = {len(embeddings[uniprot_id])} | Chunks = {len(chunk_embs)}")


# Save to JSON
with open(output_json, "w") as f:
    json.dump(embeddings, f)

print(f"\nSaved embeddings to: {output_json}")

